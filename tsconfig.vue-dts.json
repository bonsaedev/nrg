{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rootDir": "src",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/toolkit/types/shims"
  },
  "files": [
    "src/core/client/shims/globals.d.ts",
    "src/core/client/shims/components.d.ts"
  ],
  "include": ["src/core/client/form/components/*.vue"],
  "exclude": ["node_modules"]
}
