{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "paths": {
      "@/*": ["../src/*"],
      "@mocks/*": ["./core/server/mocks/*"],
      "@bonsae/nrg/server": ["../src/core/server/index.ts"],
      "@bonsae/nrg-runtime": ["../src/core/runtime.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "fixtures/**", "core/client/**"]
}
