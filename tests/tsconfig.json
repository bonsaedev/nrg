{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "paths": {
      "@/*": ["../src/*"],
      "@mocks/*": ["./sdk/server/mocks/*"],
      "@bonsae/nrg/server": ["../src/sdk/lib/server/index.ts"],
      "@bonsae/nrg-runtime": ["../src/sdk/lib/runtime.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "fixtures/**", "sdk/client/**"]
}
