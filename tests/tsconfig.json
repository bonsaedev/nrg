{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "baseUrl": ".",
    "paths": {
      "@/core/*": ["../packages/runtime/src/*"],
      "@/vite/*": ["../packages/toolkit/src/vite/*"],
      "@/test/*": ["../packages/toolkit/src/test/*"],
      "@mocks/*": ["core/server/mocks/*"],
      "@bonsae/nrg/server": ["../packages/runtime/src/server/index.ts"],
      "@bonsae/nrg-runtime/server": ["../packages/runtime/src/server/index.ts"],
      "@bonsae/nrg-runtime/internal": ["../packages/runtime/src/internal.ts"],
      "@bonsae/nrg-runtime/internal/client": [
        "../packages/runtime/src/internal-client.ts"
      ],
      "@bonsae/nrg-runtime/internal/components": [
        "../packages/runtime/src/internal-components.ts"
      ]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "fixtures/**", "core/client/**"]
}
