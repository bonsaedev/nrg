{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "baseUrl": ".",
    "paths": {
      "@/core/*": ["../packages/toolkit/src/core/*"],
      "@/vite/*": ["../packages/toolkit/src/vite/*"],
      "@/test/*": ["../packages/toolkit/src/test/*"],
      "@mocks/*": ["core/server/mocks/*"],
      "@bonsae/nrg/server": ["../packages/toolkit/src/core/server/index.ts"],
      "@bonsae/nrg-runtime/server": [
        "../packages/toolkit/src/core/server/index.ts"
      ]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "fixtures/**", "core/client/**"]
}
