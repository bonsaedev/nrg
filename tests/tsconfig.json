{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "baseUrl": ".",
    "paths": {
      "@/core/*": ["../src/core/*"],
      "@/vite/*": ["../src/vite/*"],
      "@/test/*": ["../src/test/*"],
      "@mocks/*": ["core/server/mocks/*"],
      "@bonsae/nrg/server": ["../src/core/server/index.ts"],
      "@bonsae/nrg-runtime/server": ["../src/core/server/index.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "fixtures/**", "core/client/**"]
}
