{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "noEmit": true,
    "paths": {
      "@/schemas/*": ["../shared/schemas/*"]
    }
  },
  "include": ["**/*.ts", "../shared/**/*.ts"]
}
