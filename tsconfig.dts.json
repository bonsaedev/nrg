{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": ".dts-tmp",
    "stripInternal": true,
    "esModuleInterop": true,
    "types": ["node", "jquery"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.vue",
    "dist",
    "src/sdk/test/server/shims",
    "src/sdk/test/server/unit/sent-augment.d.ts"
  ]
}
