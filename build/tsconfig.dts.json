{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "../.dts-tmp",
    "stripInternal": true,
    "esModuleInterop": true,
    "types": ["node", "jquery"],
    "baseUrl": "..",
    "paths": {
      "@/*": ["src/*"],
      "@bonsae/nrg/server": ["src/core/server/index.ts"]
    }
  },
  "include": ["../src/**/*.ts"],
  "exclude": ["../src/**/*.vue", "../tests/**", "../dist/**"]
}
