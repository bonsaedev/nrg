{
  "name": "@bonsae/nrg-runtime",
  "version": "0.25.0",
  "description": "Runtime for Node-RED nodes built with @bonsae/nrg — no build tooling.",
  "author": "Allan Oricil <allanoricil@duck.com>",
  "license": "MIT",
  "type": "commonjs",
  "homepage": "https://bonsaedev.github.io/nrg/",
  "bugs": {
    "url": "https://github.com/bonsaedev/nrg/issues"
  },
  "repository": {
    "url": "git+https://github.com/bonsaedev/nrg.git",
    "type": "git",
    "directory": "packages/runtime"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "engines": {
    "node": ">=20.19",
    "pnpm": ">=10.11.0"
  },
  "keywords": [
    "node-red",
    "vue",
    "vue3",
    "typescript",
    "json-schema",
    "iot",
    "automation",
    "low-code",
    "framework"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "./server": {
      "types": "./dist/types/server.d.ts",
      "require": "./dist/server/index.cjs",
      "default": "./dist/server/index.cjs"
    },
    "./client": {
      "types": "./dist/types/client.d.ts"
    },
    "./internal/server": {
      "types": "./dist/types/internal/server/index.d.ts",
      "require": "./dist/internal/server/index.cjs",
      "default": "./dist/internal/server/index.cjs"
    },
    "./internal/client": {
      "types": "./dist/types/internal/client/index.d.ts",
      "import": "./dist/internal/client/index.mjs",
      "default": "./dist/internal/client/index.mjs"
    },
    "./internal/client/components": {
      "types": "./dist/types/internal/client/components.d.ts",
      "import": "./dist/internal/client/components.mjs",
      "default": "./dist/internal/client/components.mjs"
    }
  },
  "scripts": {
    "build": "tsx build.ts"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.33",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "ajv-errors": "^3.0.0",
    "vue": "^3.5.14"
  }
}
