{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rootDir": "src",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types/shims"
  },
  "files": ["src/client/globals.d.ts", "src/client/components.d.ts"],
  "include": ["src/client/form/components/*.vue"],
  "exclude": ["node_modules"]
}
