{
  "name": "@bonsae/vite",
  "version": "0.0.1",
  "description": "Vite plugin to develop Node-RED packages with the NRG framework",
  "author": "Allan Oricil <allanoricil@duck.com>",
  "license": "MIT",
  "type": "module",
  "repository": {
    "url": "https://github.com/bonsae/bonsae-nrg",
    "type": "git",
    "directory": "packages/vite"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.11.0"
  },
  "scripts": {
    "build": "esbuild index.ts utils.ts --bundle --packages=external --format=esm --platform=node --outdir=dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": "./dist/index.js",
    "./utils": "./dist/utils.js"
  },
  "peerDependencies": {
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "chokidar": "^5.0.0",
    "detect-port": "^2.1.0",
    "esbuild": "^0.25.4",
    "get-port": "^7.1.0",
    "mime-types": "^3.0.1",
    "tree-kill": "^1.2.2",
    "typescript": "^5.8.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.1.0"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.15.18",
    "typescript": "^5.8.3",
    "vite": "^6.3.4"
  }
}
