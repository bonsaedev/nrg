{
  "name": "@bonsae/nrg",
  "version": "0.21.2",
  "description": "NRG framework — build Node-RED nodes with Vue 3, TypeScript, and JSON Schema",
  "author": "Allan Oricil <allanoricil@duck.com>",
  "license": "MIT",
  "type": "module",
  "homepage": "https://bonsaedev.github.io/nrg/",
  "bugs": {
    "url": "https://github.com/bonsaedev/nrg/issues"
  },
  "repository": {
    "url": "git+https://github.com/bonsaedev/nrg.git",
    "type": "git",
    "directory": "packages/toolkit"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "engines": {
    "node": ">=20.19",
    "pnpm": ">=10.11.0"
  },
  "keywords": [
    "node-red",
    "vue",
    "vue3",
    "typescript",
    "json-schema",
    "vite",
    "vitest",
    "iot",
    "automation",
    "low-code",
    "framework"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/types/server.d.ts",
      "require": "./dist/server/index.cjs",
      "default": "./dist/server/index.cjs"
    },
    "./client": {
      "types": "./dist/types/client.d.ts"
    },
    "./vite": {
      "types": "./dist/types/vite.d.ts",
      "default": "./dist/vite/index.js"
    },
    "./test/server/unit": {
      "types": "./dist/types/test-server-unit.d.ts",
      "default": "./dist/test/server/unit/index.js"
    },
    "./test/server/unit/config": "./dist/test/server/unit/config.js",
    "./test/server/integration": {
      "types": "./dist/types/test-server-integration.d.ts",
      "default": "./dist/test/server/integration/index.js"
    },
    "./test/server/integration/config": "./dist/test/server/integration/config.js",
    "./test/client/component": {
      "types": "./dist/types/test-client-component.d.ts",
      "default": "./dist/test/client/component/index.js"
    },
    "./test/client/component/config": "./dist/test/client/component/config.js",
    "./test/client/component/setup": "./dist/test/client/component/setup.js",
    "./test/client/unit": {
      "types": "./dist/types/test-client-unit.d.ts",
      "default": "./dist/test/client/unit/index.js"
    },
    "./test/client/unit/config": "./dist/test/client/unit/config.js",
    "./test/client/unit/setup": "./dist/test/client/unit/setup.js",
    "./test/client/e2e": {
      "types": "./dist/types/test-client-e2e.d.ts",
      "default": "./dist/test/client/e2e/index.js"
    },
    "./test/client/e2e/config": "./dist/test/client/e2e/config.js",
    "./tsconfig/base.json": "./dist/tsconfig/base.json",
    "./tsconfig/core/server.json": "./dist/tsconfig/core/server.json",
    "./tsconfig/core/client.json": "./dist/tsconfig/core/client.json",
    "./tsconfig/test/server/unit.json": "./dist/tsconfig/test/server/unit.json",
    "./tsconfig/test/server/integration.json": "./dist/tsconfig/test/server/integration.json",
    "./tsconfig/test/client/component.json": "./dist/tsconfig/test/client/component.json",
    "./tsconfig/test/client/unit.json": "./dist/tsconfig/test/client/unit.json",
    "./tsconfig/test/client/e2e.json": "./dist/tsconfig/test/client/e2e.json"
  },
  "scripts": {
    "build": "tsx build.ts"
  },
  "peerDependencies": {
    "@vitest/browser-playwright": "^4.0.0",
    "@vitest/coverage-istanbul": "^4.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "happy-dom": "^20.0.0",
    "playwright": "^1.50.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0",
    "vitest-browser-vue": "^2.0.0",
    "vue": "^3.5.14"
  },
  "peerDependenciesMeta": {
    "happy-dom": {
      "optional": true
    },
    "@vitest/coverage-istanbul": {
      "optional": true
    },
    "@vitest/coverage-v8": {
      "optional": true
    },
    "@vitest/browser-playwright": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "vitest-browser-vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@bonsae/nrg-runtime": "workspace:*",
    "@clack/prompts": "^1.0.1",
    "@sinclair/typebox": "^0.34.33",
    "@vitejs/plugin-vue": "^5.2.3",
    "ajv": "^8.17.1",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "chokidar": "^5.0.0",
    "detect-port": "^2.1.0",
    "es-toolkit": "^1.37.2",
    "esbuild": "^0.25.4",
    "get-port": "^7.1.0",
    "jsonpointer": "^5.0.1",
    "mime-types": "^3.0.1",
    "tree-kill": "^1.2.2",
    "typescript": "^5.8.3",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.14"
  }
}
