{
  "name": "@bonsae/nrg",
  "version": "0.7.0",
  "description": "NRG framework — build Node-RED nodes with Vue 3, TypeScript, and JSON Schema",
  "author": "Allan Oricil <allanoricil@duck.com>",
  "license": "MIT",
  "type": "module",
  "repository": {
    "url": "https://github.com/bonsaedev/nrg",
    "type": "git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.11.0"
  },
  "scripts": {
    "test": "vitest run && vitest run --config vitest.e2e.config.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "build": "node build.mjs",
    "typecheck": "tsc -p src/core/server/tsconfig.json --noEmit && tsc -p src/core/client/tsconfig.json --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,json}\"",
    "docs:dev": "pnpm --dir docs dev",
    "docs:build": "pnpm --dir docs build",
    "docs:preview": "pnpm --dir docs preview",
    "prepare": "husky"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/types/server.d.ts",
      "require": "./dist/server/index.cjs",
      "default": "./dist/server/index.cjs"
    },
    "./client": {
      "types": "./dist/types/client.d.ts"
    },
    "./vite": {
      "types": "./dist/types/vite.d.ts",
      "default": "./dist/vite/index.js"
    },
    "./tsconfig/base.json": "./dist/tsconfig/base.json",
    "./tsconfig/client.json": "./dist/tsconfig/client.json",
    "./tsconfig/server.json": "./dist/tsconfig/server.json"
  },
  "peerDependencies": {
    "vite": "^6.0.0",
    "vue": "^3.5.14"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@sinclair/typebox": "^0.34.33",
    "@vitejs/plugin-vue": "^5.2.3",
    "ajv": "^8.17.1",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "chokidar": "^5.0.0",
    "detect-port": "^2.1.0",
    "es-toolkit": "^1.37.2",
    "esbuild": "^0.25.4",
    "get-port": "^7.1.0",
    "jsonpointer": "^5.0.1",
    "mime-types": "^3.0.1",
    "tree-kill": "^1.2.2",
    "typescript": "^5.8.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.1.0"
  },
  "lint-staged": {
    "src/**/*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.json": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.27.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/express": "^5.0.1",
    "@types/jquery": "^4.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.15.18",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/coverage-v8": "^4.1.5",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.1.0",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "semantic-release": "^24.2.4",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.4",
    "vitest": "^4.1.5",
    "vue": "^3.5.14"
  }
}
