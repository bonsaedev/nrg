{
  "name": "bonsae-nrg",
  "version": "0.22.0",
  "description": "NRG monorepo — @bonsae/nrg (toolkit) + @bonsae/nrg-runtime",
  "author": "Allan Oricil <allanoricil@duck.com>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://bonsaedev.github.io/nrg/",
  "bugs": {
    "url": "https://github.com/bonsaedev/nrg/issues"
  },
  "repository": {
    "url": "git+https://github.com/bonsaedev/nrg.git",
    "type": "git"
  },
  "engines": {
    "node": ">=20.19",
    "pnpm": ">=10.11.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:runtime": "pnpm --filter @bonsae/nrg-runtime build",
    "build:toolkit": "pnpm --filter @bonsae/nrg build",
    "test": "pnpm test:core && pnpm test:vite",
    "test:core": "pnpm test:core:server && pnpm test:core:client",
    "test:core:server": "pnpm test:core:server:unit && pnpm test:core:server:integration",
    "test:core:server:unit": "vitest run --config vitest.core.server.unit.config.ts",
    "test:core:server:integration": "vitest run --config vitest.core.server.integration.config.ts",
    "test:core:server:integration:watch": "vitest --config vitest.core.server.integration.config.ts",
    "test:core:server:unit:watch": "vitest --config vitest.core.server.unit.config.ts",
    "test:core:client": "pnpm test:core:client:unit && pnpm test:core:client:component && pnpm test:core:client:e2e",
    "test:core:client:unit": "vitest run --config vitest.core.client.unit.config.ts",
    "test:core:client:unit:watch": "vitest --config vitest.core.client.unit.config.ts",
    "test:core:client:component": "vitest run --config vitest.core.client.component.config.ts",
    "test:core:client:component:watch": "vitest --config vitest.core.client.component.config.ts",
    "test:core:client:e2e": "vitest run --config vitest.core.client.e2e.config.ts",
    "test:vite": "pnpm test:vite:unit && pnpm test:vite:e2e",
    "test:vite:unit": "vitest run --config vitest.vite.unit.config.ts",
    "test:vite:unit:watch": "vitest --config vitest.vite.unit.config.ts",
    "test:vite:e2e": "vitest run --config vitest.vite.e2e.config.ts",
    "test:smoke": "tsx tests/smoke/consumer-smoke.ts",
    "validate": "pnpm validate:tsc && pnpm validate:lint && pnpm validate:format",
    "validate:tsc": "tsc -p packages/runtime/tsconfig.json --noEmit && tsc -p packages/runtime/tsconfig.client.json --noEmit && tsc -p packages/toolkit/tsconfig.json --noEmit && tsc -p tests/tsconfig.json --noEmit && tsc -p tests/core/client/unit/tsconfig.json --noEmit && tsc -p tests/core/client/component/tsconfig.json --noEmit && tsc -p tests/core/client/e2e/tsconfig.json --noEmit",
    "validate:lint": "eslint packages/",
    "validate:format": "prettier --check \"packages/**/*.{ts,vue,json}\"",
    "lint": "eslint packages/ --fix",
    "format": "prettier --write \"packages/**/*.{ts,vue,json}\"",
    "docs:dev": "pnpm --dir docs dev",
    "docs:build": "pnpm --dir docs build",
    "docs:preview": "pnpm --dir docs preview",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/**/*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "prettier --write"
    ],
    "packages/**/*.json": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@clack/prompts": "^1.0.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.27.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@sinclair/typebox": "^0.34.33",
    "@types/express": "^5.0.1",
    "@types/jquery": "^4.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.15.18",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.5",
    "ajv": "^8.17.1",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "chokidar": "^5.0.0",
    "detect-port": "^2.1.0",
    "dts-bundle-generator": "^9.5.1",
    "es-toolkit": "^1.37.2",
    "esbuild": "^0.25.4",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.1.0",
    "get-port": "^7.1.0",
    "globals": "^16.1.0",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "jsonpointer": "^5.0.1",
    "lint-staged": "^16.4.0",
    "mime-types": "^3.0.1",
    "node-red": "5.0.0",
    "playwright": "^1.60.0",
    "prettier": "^3.5.3",
    "semantic-release": "^24.2.4",
    "tree-kill": "^1.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.4",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.1.0",
    "vitest": "^4.1.5",
    "vitest-browser-vue": "^2.1.0",
    "vue": "^3.5.14",
    "vue-tsc": "^3.2.8",
    "zod": "^4.4.3"
  }
}
