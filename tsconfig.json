{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node", "jquery"],
    "paths": {
      "@/*": ["./src/*"],
      "@bonsae/nrg/server": ["./src/sdk/lib/server/index.ts"],
      "@bonsae/nrg-runtime": ["./src/sdk/lib/runtime.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
