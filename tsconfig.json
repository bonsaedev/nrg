{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "noImplicitAny": false,
    "noImplicitOverride": true,
    "resolveJsonModule": true
  },
  "exclude": ["node_modules", "dist"]
}
